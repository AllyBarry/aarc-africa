---
import BaseLayout from "../layouts/BaseLayout.astro";
import EventNav from "../components/EventNav.astro";

// Webinar data — newest first within each group.
// `photo` is a path under /public; leave null to show a placeholder avatar.
const upcoming: Array<{
  number: string;
  title: string;
  speaker: string;
  affiliation?: string;
  date: string;
  time: string;
  blurb: string;
  tags: string[];
  photo: string | null;
  registerUrl?: string;
}> = [
  {
    number: "Webinar 02",
    title: "Speaker & topic to be announced",
    speaker: "Speaker TBC",
    date: "29 July 2026",
    time: "16:00 SAST",
    blurb:
      "Our next webinar is being finalised. We're lining up another leading voice in African robotics to share their research and perspective on where the field is heading. Speaker and topic details will be announced soon — save the date and check back for the full lineup.",
    tags: ["To Be Announced"],
    photo: null,
  },
];

const past = [
  {
    number: "Webinar 01",
    title: "Studying Cheetahs Through the Lens of Robotics: An African Perspective",
    speaker: "Prof. Amir Patel",
    date: "24 June 2026",
    time: "16:00 SAST",
    blurb:
      "How do cheetahs move with such incredible speed and agility? This inaugural AARC webinar explored how robotics, computer vision, control engineering, and advanced sensing technologies are helping researchers unlock the secrets of animal locomotion — and what this means for the future of robotics, conservation, and innovation in Africa. A fascinating conversation at the intersection of robotics, wildlife science, and African technological leadership.",
    tags: ["Locomotion", "Computer Vision", "Control", "Conservation"],
    photo: "/images/people/amir.jpg",
    recordingUrl: null as string | null,
  },
];
---

<BaseLayout
  title="Webinars — AARC"
  description="AARC webinar series — talks from researchers and innovators at the frontier of African robotics. Watch past sessions and register for what's coming next."
>
  <main class="mx-auto max-w-6xl px-6 pt-12 pb-24 lg:px-8">
    <!-- Header -->
    <div class="reveal mb-16">
      <div class="mb-8 flex items-center justify-between gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-orange-300 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          Back to home
        </a>
        <EventNav
          links={[
            { label: "About", href: "#about" },
            { label: "Upcoming", href: "#upcoming" },
            { label: "Past Webinars", href: "#past" },
          ]}
        />
      </div>

      <p class="mb-6 text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">
        AARC Events · Webinar Series
      </p>
      <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight">Webinars</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-400">
        The AARC webinar series brings researchers, engineers, and innovators from
        across the continent and beyond into conversation with our community &mdash;
        online, and open to all. Explore what&rsquo;s coming up next and catch up on
        sessions you may have missed.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <span class="inline-flex items-center gap-2 rounded-full border border-cyan-400/25 bg-cyan-400/10 px-3 py-1 text-xs font-semibold text-cyan-200 uppercase tracking-widest">Online</span>
        <span class="inline-flex items-center gap-2 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 text-xs font-semibold text-emerald-200 uppercase tracking-widest">Free to Attend</span>
        <span class="inline-flex items-center gap-2 rounded-full border border-orange-400/25 bg-orange-400/10 px-3 py-1 text-xs font-semibold text-orange-200 uppercase tracking-widest">Open to Everyone</span>
      </div>
    </div>

    <!-- About -->
    <div id="about" class="reveal scroll-mt-24 panel rounded-3xl p-8 mb-16">
      <p class="mb-1 text-xs font-semibold uppercase tracking-[0.22em] text-orange-300/80">About the series</p>
      <h2 class="mt-2 text-2xl font-bold text-white">Ideas at the frontier of African robotics</h2>
      <p class="mt-4 leading-8 text-slate-300">
        Each webinar features a leading voice in robotics, AI, and intelligent systems &mdash;
        sharing their research, their journey, and their perspective on where the field is
        heading. Sessions are live, interactive, and always free to join.
      </p>
      <p class="mt-4 leading-8 text-slate-300">
        Want to be first to hear about upcoming talks?
        <a href="https://discord.gg/pvXMR8vcpV" target="_blank" rel="noopener noreferrer" class="text-orange-300 hover:text-orange-200 transition-colors">Join our Discord</a>
        &mdash; that&rsquo;s where we announce speakers, dates, and joining links.
      </p>
    </div>

    <!-- Upcoming -->
    <div id="upcoming" class="reveal scroll-mt-24 mb-6">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">Upcoming</p>
      <h2 class="text-3xl font-bold text-white">Coming up next</h2>
    </div>

    {
      upcoming.length > 0 ? (
        <div class="space-y-6 mb-16">
          {upcoming.map((w) => (
            <div class="reveal panel rounded-3xl p-8">
              <div class="flex flex-wrap items-center gap-3">
                <span class="inline-flex items-center gap-2 rounded-full border border-orange-400/25 bg-orange-400/10 px-3 py-1 text-xs font-semibold text-orange-200 uppercase tracking-widest">{w.number}</span>
                <span class="inline-flex items-center gap-2 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 text-xs font-semibold text-emerald-200 uppercase tracking-widest">Upcoming</span>
              </div>
              <div class="mt-5 flex items-start gap-5">
                <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full border-2 border-orange-400/25 ring-2 ring-orange-400/10">
                  {w.photo ? (
                    <img src={w.photo} alt={w.speaker} class="h-full w-full object-cover" />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-white/5 text-slate-500">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                    </div>
                  )}
                </div>
                <div>
                  <h3 class="text-2xl font-bold text-white leading-snug">{w.title}</h3>
                  <p class="mt-2 text-lg font-semibold text-orange-300/90">{w.speaker}{w.affiliation && <span class="text-slate-400 font-normal"> &middot; {w.affiliation}</span>}</p>
                  <div class="mt-3 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-300">
                    <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-orange-400" />{w.date}</span>
                    <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-orange-400" />{w.time}</span>
                  </div>
                </div>
              </div>
              <p class="mt-5 leading-8 text-slate-300">{w.blurb}</p>
              <div class="mt-6 flex flex-wrap gap-2">
                {w.tags.map((t) => (
                  <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-300">{t}</span>
                ))}
              </div>
              {w.registerUrl && (
                <a href={w.registerUrl} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center gap-2 rounded-xl bg-emerald-400/15 border border-emerald-400/25 px-4 py-2 text-sm font-semibold text-emerald-200 transition-colors hover:bg-emerald-400/25">Register now &rarr;</a>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="reveal panel rounded-3xl p-8 mb-16 text-center">
          <p class="text-lg font-semibold text-white">No webinars are scheduled right now.</p>
          <p class="mt-3 max-w-xl mx-auto leading-7 text-slate-400">
            We&rsquo;re lining up our next speaker &mdash; check back soon for the next session.
          </p>
        </div>
      )
    }

    <!-- Past -->
    <div id="past" class="reveal scroll-mt-24 mb-6">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">Past Webinars</p>
      <h2 class="text-3xl font-bold text-white">Catch up on what you missed</h2>
    </div>

    <div class="space-y-6 mb-16">
      {
        past.map((w) => (
          <div class="reveal group rounded-3xl border border-white/5 bg-white/[0.02] p-8 opacity-80 transition-opacity hover:opacity-100">
            <div class="flex flex-wrap items-center gap-3">
              <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-slate-400 uppercase tracking-widest">{w.number}</span>
              <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-slate-400 uppercase tracking-widest">Past Event</span>
            </div>
            <div class="mt-5 flex items-start gap-5">
              <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full border-2 border-white/10 ring-2 ring-white/5">
                {w.photo ? (
                  <img src={w.photo} alt={w.speaker} class="h-full w-full object-cover grayscale transition-all duration-300 group-hover:grayscale-0" />
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-white/5 text-slate-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  </div>
                )}
              </div>
              <div>
                <h3 class="text-2xl font-bold text-slate-200 leading-snug">{w.title}</h3>
                <p class="mt-2 text-lg font-semibold text-slate-400">{w.speaker}</p>
                <div class="mt-3 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-400">
                  <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-slate-500" />{w.date}</span>
                  <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-slate-500" />{w.time}</span>
                </div>
              </div>
            </div>
            <p class="mt-5 leading-8 text-slate-400">{w.blurb}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              {w.tags.map((t) => (
                <span class="rounded-full border border-white/5 bg-white/[0.03] px-3 py-1 text-xs text-slate-400">{t}</span>
              ))}
            </div>
            {w.recordingUrl && (
              <a href={w.recordingUrl} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center gap-2 rounded-full border border-amber-400/40 bg-gradient-to-r from-orange-500/20 to-amber-400/20 px-4 py-2 text-sm font-medium text-amber-300 transition-all hover:border-amber-400/70 hover:from-orange-500/30 hover:to-amber-400/30 hover:text-amber-200">Watch recording &rarr;</a>
            )}
          </div>
        ))
      }
    </div>

    <!-- Closing CTA -->
    <div class="reveal panel orange-glow rounded-[2rem] p-8 md:p-12 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">Never miss a session</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-white">Join the conversation.</h2>
      <p class="mt-4 max-w-2xl mx-auto text-slate-300 leading-7">
        Speaker announcements, joining links, and recordings all land in our Discord first.
        Come and be part of the African robotics community.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a href="https://discord.gg/pvXMR8vcpV" target="_blank" rel="noopener noreferrer" class="primary-btn">Join our Discord</a>
        <a href="/" class="secondary-btn">Back to home</a>
      </div>
    </div>
  </main>
</BaseLayout>
