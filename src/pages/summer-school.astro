    <script>
      const ot = document.getElementById("organizers-track") as HTMLElement;
      const od = document.getElementById("organizers-dots") as HTMLElement;
      const oc = Array.from(ot.children) as HTMLElement[];

      oc.forEach((_, i) => {
        const dot = document.createElement("button");
        dot.setAttribute("aria-label", `Go to organizer ${i + 1}`);
        dot.className = "h-2 w-2 rounded-full bg-white/20 transition-colors";
        dot.addEventListener("click", () =>
          ot.scrollTo({ left: oc[i].offsetLeft, behavior: "smooth" }),
        );
        od.appendChild(dot);
      });

      function activeIndex() {
        const mid = ot.scrollLeft + ot.clientWidth / 2;
        let idx = 0;
        oc.forEach((c, i) => {
          if (c.offsetLeft <= mid) idx = i;
        });
        return idx;
      }

      function syncDots() {
        const a = activeIndex();
        Array.from(od.children).forEach((d, i) => {
          (d as HTMLElement).className =
            `h-2 rounded-full transition-all ${i === a ? "w-6 bg-orange-400" : "w-2 bg-white/20"}`;
        });
      }

      function visCount() {
        return window.innerWidth >= 1024
          ? 5
          : window.innerWidth >= 640
            ? 2
            : 1;
      }

      document
        .getElementById("organizers-prev")
        ?.addEventListener("click", () => {
          ot.scrollTo({
            left: oc[Math.max(0, activeIndex() - visCount())].offsetLeft,
            behavior: "smooth",
          });
        });
      document
        .getElementById("organizers-next")
        ?.addEventListener("click", () => {
          ot.scrollTo({
            left: oc[Math.min(oc.length - 1, activeIndex() + visCount())]
              .offsetLeft,
            behavior: "smooth",
          });
        });

      ot.addEventListener("scroll", syncDots, { passive: true });
      syncDots();
    </script>

