---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="ICRA 2026 Africa Satellite — AARC"
  description=""
>

  <main class="mx-auto max-w-6xl px-6 pt-12 pb-24 lg:px-8">

    <!-- Header -->
    <div class="reveal mb-16">
      <a href="/" class="mb-8 inline-flex items-center gap-2 text-sm text-slate-400 hover:text-orange-300 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to home
      </a>
      <p class="mb-6 text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">Upcoming Event · 2&ndash;4 June 2026</p>
      <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight">IEEE <span class="nasal-title">ICRA</span> 2026</h1>
      <p class="mb-8 text-2xl md:text-4xl font-semibold text-slate-300 leading-snug">Johannesburg Satellite Conference Center</p>
      <p class="max-w-2xl text-lg leading-8 text-slate-400">
        AARC is proud to host an official Satellite Conference Center for the IEEE International Conference
        on Robotics and Automation 2026 in collaboration with the University of the Witwatersrand &mdash; bringing the world&rsquo;s flagship robotics conference to
        South Africa, live from Vienna.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <span class="inline-flex items-center gap-2 rounded-full border border-orange-400/25 bg-orange-400/10 px-3 py-1 text-xs font-semibold text-orange-200 uppercase tracking-widest">Live Streaming</span>
        <span class="inline-flex items-center gap-2 rounded-full border border-cyan-400/25 bg-cyan-400/10 px-3 py-1 text-xs font-semibold text-cyan-200 uppercase tracking-widest">In-Person</span>
        <span class="inline-flex items-center gap-2 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 text-xs font-semibold text-emerald-200 uppercase tracking-widest">Free to Attend</span>
      </div>
    </div>

    <!-- About -->
    <div class="reveal panel rounded-3xl p-8 mb-10">
      <p class="mb-1 text-xs font-semibold uppercase tracking-[0.22em] text-orange-300/80">About</p>
      <h2 class="mt-2 text-2xl font-bold text-white">Bringing ICRA to Africa</h2>
      <p class="mt-4 leading-8 text-slate-300">
        The <strong class="text-white">IEEE International Conference on Robotics and Automation (ICRA)</strong>
        is the world&rsquo;s largest and most influential gathering of robotics researchers and practitioners.
        ICRA 2026 takes place <strong class="text-white">1&ndash;5 June 2026 in Vienna, Austria</strong>, and for
        many African researchers, attending in person is prohibitive due to cost, visa logistics, and travel time.
      </p>
      <p class="mt-4 leading-8 text-slate-300">
        ICRA&rsquo;s <strong class="text-white">Satellite Conference Center</strong> programme exists to close
        that gap. AARC is hosting Johannesburg&rsquo;s satellite center at the <strong class="text-white">University of the Witwatersrand</strong>
        &mdash; offering live-streamed access to keynote, panel and plenary sessions.
      </p>
      <p class="mt-4 leading-8 text-slate-300">
        This builds on AARC&rsquo;s previous successful collaboration with IEEE &mdash; the
        <strong class="text-white">ICRA@40 Africa Satellite Event</strong> hosted at Wits in 2024.
      </p>
      <div class="mt-6 rounded-2xl border border-orange-400/15 bg-orange-400/5 p-5">
        <p class="mb-3 text-sm font-semibold text-orange-200">At a Glance</p>
        <ul class="space-y-2 text-sm leading-7 text-slate-300">
          <li class="flex gap-3"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">When:</strong>&nbsp;09:00 to 18:15, 2&ndash;4 June 2026</li>
          <li class="flex gap-3"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">Where:</strong>&nbsp;TW Kambule Mathematical Sciences Building, West Campus, University of the Witwatersrand, Enoch Sontonga Avenue, Braamfontein, Johannesburg</li>
          <li class="flex gap-3"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">Format:</strong>&nbsp;Live-streamed ICRA sessions</li>
          <li class="flex gap-3"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">Cost:</strong>&nbsp;Free to attend</li>
          <li class="flex gap-3"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">Open to:</strong>&nbsp;Researchers, students, engineers, and industry practitioners</li>
        </ul>
      </div>
      <div class="mt-4 rounded-2xl border border-emerald-400/15 bg-emerald-400/5 p-5">
        <p class="mb-1 text-sm font-semibold text-emerald-200">Registration</p>
        <p class="mt-1 text-sm leading-7 text-slate-300">
          Attendance is free but places are limited &mdash; please register before <strong class="text-white">22 May 2026</strong>.
          Registered attendees will receive the detailed programme and any schedule updates directly by email.
        </p>
        
          href="https://docs.google.com/forms/d/e/1FAIpQLSccYB3_QTrlu5ek2mYS26ALBa7mlsIAKBqmn8clzLypk_M9Ng/viewform?usp=header"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 rounded-xl bg-emerald-400/15 border border-emerald-400/25 px-4 py-2 text-sm font-semibold text-emerald-200 transition-colors hover:bg-emerald-400/25"
        >
          Register now &rarr;
        </a>
      </div>
    </div>

    <!-- What you'll experience -->
    <div class="reveal mb-4">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">Programme</p>
      <h2 class="text-3xl font-bold text-white">What you&rsquo;ll experience</h2>
      <p class="mt-4 leading-8 text-slate-400">
        Attendees will have direct access to ICRA&rsquo;s flagship sessions, broadcast live from Vienna.
        Sessions run 09:00&ndash;18:15 daily (SAST, UTC+2).
      </p>
    </div>

    <!-- Schedule tabs -->
    <div class="reveal panel rounded-3xl p-8 mb-10">

      <!-- Legend -->
      <div class="mb-6 flex flex-wrap gap-3 text-xs font-semibold">
        <span class="inline-flex items-center gap-1.5 rounded-full border border-orange-400/20 bg-orange-400/10 px-3 py-1 text-orange-200">
          <span class="h-1.5 w-1.5 rounded-full bg-orange-400"></span> Keynote
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-cyan-200">
          <span class="h-1.5 w-1.5 rounded-full bg-cyan-400"></span> Plenary
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-emerald-200">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span> Panel
        </span>
      </div>

      <!-- ICRA session links -->
      <p class="mb-6 text-sm leading-7 text-slate-400">
        Full details for each session are available on the ICRA 2026 website:
        <a href="https://2026.ieee-icra.org/attend/keynote-sessions/" target="_blank" rel="noopener noreferrer" class="text-orange-300 hover:text-orange-200 transition-colors">keynote sessions</a>
        and
        <a href="https://2026.ieee-icra.org/attend/plenary-sessions/" target="_blank" rel="noopener noreferrer" class="text-orange-300 hover:text-orange-200 transition-colors">plenary sessions</a>.
      </p>

      <!-- Day tabs -->
      <div class="mb-6 flex flex-wrap gap-2" role="tablist">
        <button
          id="tab-tue"
          role="tab"
          aria-selected="true"
          aria-controls="panel-tue"
          class="sched-tab rounded-lg border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-semibold text-white transition-colors"
          onclick="schedDay('tue')"
        >Tue 2 June</button>
        <button
          id="tab-wed"
          role="tab"
          aria-selected="false"
          aria-controls="panel-wed"
          class="sched-tab rounded-lg border border-white/10 px-4 py-1.5 text-sm font-medium text-slate-400 transition-colors hover:border-white/20 hover:text-slate-200"
          onclick="schedDay('wed')"
        >Wed 3 June</button>
        <button
          id="tab-thu"
          role="tab"
          aria-selected="false"
          aria-controls="panel-thu"
          class="sched-tab rounded-lg border border-white/10 px-4 py-1.5 text-sm font-medium text-slate-400 transition-colors hover:border-white/20 hover:text-slate-200"
          onclick="schedDay('thu')"
        >Thu 4 June</button>
      </div>

      <!-- Tuesday -->
      <div id="panel-tue" role="tabpanel" aria-labelledby="tab-tue" class="sched-day divide-y divide-white/5">

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">09:00–10:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-200">Panel</span>
            <p class="text-sm font-semibold text-white">From Humanoid Robotics Research to Startup Creation: The Role of Public Funding</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">11:00–12:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-orange-400/20 bg-orange-400/10 px-2.5 py-0.5 text-xs font-semibold text-orange-200">Keynotes</span>
            <ul class="space-y-2 text-sm text-slate-300">
              <li><strong class="text-white">Johannes Betz</strong> &mdash; Learning to Handle Autonomous Vehicles at the Limits: Lessons Learned from Real-World Autonomous Motorsport</li>
              <li><strong class="text-white">Michael Milford</strong> &mdash; From Neuroscience to Autonomous Vehicle Navigation</li>
              <li><strong class="text-white">Aniket Bera</strong> &mdash; Toward Behaviorally-Intelligent Robots: Safe Navigation in Unstructured and Human-Centered Environments</li>
              <li><strong class="text-white">Hesheng Wang</strong> &mdash; Learning to Navigate: From Scene Understanding to Decision Making</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">14:00–14:50</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-200">Plenary</span>
            <p class="text-sm text-slate-300"><strong class="text-white">Ken Goldberg</strong> &mdash; Can GOFE and Code-as-Policy Close the 100,000-Year &ldquo;Data Gap&rdquo; in Robot Manipulation?</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">15:00–16:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-200">Panel</span>
            <p class="text-sm font-semibold text-white">Advancing Sustainability in Robotics: From Green Design to Real-World Impact</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">16:45–18:15</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-orange-400/20 bg-orange-400/10 px-2.5 py-0.5 text-xs font-semibold text-orange-200">Keynotes</span>
            <ul class="space-y-2 text-sm text-slate-300">
              <li><strong class="text-white">Eric Diller</strong> &mdash; Using Magnetic Fields to Control Tiny Robots in the Gut and Brain</li>
              <li><strong class="text-white">Fanny Ficuciello</strong> &mdash; From Bioinspired Design to Safe Control: Emerging Challenges in Medical Robotics</li>
              <li><strong class="text-white">Tiantian Xu</strong> &mdash; Magnetically Actuated Microrobots for Precision Medicine</li>
              <li><strong class="text-white">Haoyong Yu</strong> &mdash; Towards Wearable Robotics with better Portability, Safety, and Comfort</li>
            </ul>
          </div>
        </div>

      </div><!-- /panel-tue -->

      <!-- Wednesday -->
      <div id="panel-wed" role="tabpanel" aria-labelledby="tab-wed" class="sched-day hidden divide-y divide-white/5">

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">09:00–10:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-200">Panel</span>
            <p class="text-sm font-semibold text-white">Building Sustainable and Trustworthy AI for Automation</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">11:00–12:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-orange-400/20 bg-orange-400/10 px-2.5 py-0.5 text-xs font-semibold text-orange-200">Keynotes</span>
            <ul class="space-y-2 text-sm text-slate-300">
              <li><strong class="text-white">Ayoung Kim</strong> &mdash; The Underdog Sensors: Are Robots Using Thermal and Radar Right?</li>
              <li><strong class="text-white">Luca Carlone</strong> &mdash; Maps, Memory, and Tasks: Toward Spatial AI for the Next Generation of Robots</li>
              <li><strong class="text-white">Maren Bennewitz</strong> &mdash; Advancing Service Robots Through Active Perception: Mapping and Object Search Under Occlusion</li>
              <li><strong class="text-white">Timothy Barfoot</strong> &mdash; Why Field Robotics Research Still Matters</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">14:00–14:50</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-200">Plenary</span>
            <p class="text-sm text-slate-300"><strong class="text-white">Barbara Mazzollai</strong> &mdash; Natural Revolution: Biological Principles for Frugal and Sustainable Robotics</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">15:00–16:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-200">Panel</span>
            <p class="text-sm font-semibold text-white">Surviving the Paper Deluge: A One-Year Study in Learning from Demonstration</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">16:45–18:15</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-orange-400/20 bg-orange-400/10 px-2.5 py-0.5 text-xs font-semibold text-orange-200">Keynotes</span>
            <ul class="space-y-2 text-sm text-slate-300">
              <li><strong class="text-white">Jeannette Bohg</strong> &mdash; Do We Still Need Dexterous Hands?</li>
              <li><strong class="text-white">Kento Kawaharazuka</strong> &mdash; At the Intersection of Biology and Machines: From Musculoskeletal to Wire-driven Robots</li>
              <li><strong class="text-white">Nikos Tsagarakis</strong> &mdash; Modular Bodies and Recovery Capabilities: Building Robots for Unstructured Environments</li>
              <li><strong class="text-white">Yuke Zhu</strong> &mdash; Building Generalist Humanoid Robots</li>
            </ul>
          </div>
        </div>

      </div><!-- /panel-wed -->

      <!-- Thursday -->
      <div id="panel-thu" role="tabpanel" aria-labelledby="tab-thu" class="sched-day hidden divide-y divide-white/5">

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">09:00–10:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-200">Panel</span>
            <p class="text-sm font-semibold text-white">&ldquo;Robotics for All&rdquo; in a Fragmented World: Competing Global Visions and Shared Futures from Europe, Asia, and the United States</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">11:00–12:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-orange-400/20 bg-orange-400/10 px-2.5 py-0.5 text-xs font-semibold text-orange-200">Keynotes</span>
            <ul class="space-y-2 text-sm text-slate-300">
              <li><strong class="text-white">David Hsu</strong> &mdash; Scalable Robot Decision Making in the Open World: Planning and Plan Prediction with LLMs</li>
              <li><strong class="text-white">Stefanie Tellex</strong> &mdash; Towards Complex Language in Partially Observed Environments</li>
              <li><strong class="text-white">Noemie Jaquier</strong> &mdash; Traveling the Robot Learning Manifold: A Tale of Geometries and Inductive Biases</li>
              <li><strong class="text-white">Paolo Robuffo Giordano</strong> &mdash; Intrinsic Robustness: A Journey from Control-Aware Planning to Robust Robot Learning</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">14:00–14:50</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-200">Plenary</span>
            <p class="text-sm text-slate-300"><strong class="text-white">Roland Siegwart</strong> &mdash; Aerial Robots: From Omnidirectional Flight to Physical Interaction at Height</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">15:00–16:30</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-200">Panel</span>
            <p class="text-sm font-semibold text-white">Return on Humanoid Investment</p>
          </div>
        </div>

        <div class="flex gap-4 py-4">
          <div class="w-24 shrink-0 pt-0.5 text-xs font-medium text-slate-500">16:45–18:15</div>
          <div>
            <span class="mb-2 inline-block rounded-full border border-orange-400/20 bg-orange-400/10 px-2.5 py-0.5 text-xs font-semibold text-orange-200">Keynotes</span>
            <ul class="space-y-2 text-sm text-slate-300">
              <li><strong class="text-white">Julia A. Adams</strong> &mdash; Challenges in Adaptive Robot Teaming: Understanding Human Teammate Performance</li>
              <li><strong class="text-white">Marcia O&rsquo;Malley</strong> &mdash; Guiding with Touch: Wearable Haptics for Shaping Human&ndash;Robot Interaction</li>
              <li><strong class="text-white">Tetsunari Inamura</strong> &mdash; Engineering Human Agency and Self-Efficacy: The Next Frontier of Human-Robot Symbiosis</li>
              <li><strong class="text-white">Ber Calli</strong> &mdash; Overcoming Manipulation Challenges in Environmental Robotics through AI-based Solutions and Human-Robot Partnership</li>
            </ul>
          </div>
        </div>

      </div><!-- /panel-thu -->

    </div><!-- /schedule panel -->

    <!-- Why Attend -->
    <div class="reveal mb-4">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">Why Attend</p>
      <h2 class="text-3xl font-bold text-white">Three reasons to be there</h2>
    </div>

    <div class="reveal panel rounded-3xl p-8 mb-6">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-orange-400/20 bg-orange-400/10 px-3 py-1 text-xs font-semibold text-orange-200 uppercase tracking-widest">Reason 1</div>
      <h3 class="text-xl font-bold text-white">Access without the airfare</h3>
      <p class="mt-4 leading-8 text-slate-300">
        ICRA is the most important conference in robotics, and historically the cost of attending in person has
        kept it out of reach for most African researchers and students. Our satellite center brings the same
        sessions &mdash; live, in real time &mdash; to Johannesburg, for free.
      </p>
    </div>

    <div class="reveal panel rounded-3xl p-8 mb-6">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-orange-400/20 bg-orange-400/10 px-3 py-1 text-xs font-semibold text-orange-200 uppercase tracking-widest">Reason 2</div>
      <h3 class="text-xl font-bold text-white">Connect with the African robotics community</h3>
      <p class="mt-4 leading-8 text-slate-300">
        Streaming ICRA from your laptop is one thing. Watching it alongside other African roboticists &mdash;
        and joining the conversations that happen between sessions &mdash; is entirely another. Expect to leave
        with new collaborators, mentors, and friends across the continent.
      </p>
    </div>

    <!-- Venue -->
    <div class="reveal mb-4">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">Venue</p>
      <h2 class="text-3xl font-bold text-white">Hosted at Wits University</h2>
    </div>

    <div class="reveal panel rounded-3xl p-8 mb-10">
      <p class="leading-8 text-slate-300">
        The satellite event will be held at the <strong class="text-white">University of the Witwatersrand</strong>
        in Johannesburg &mdash; home to the RAIL Lab, the MIND Institute, and one of the largest robotics and
        machine learning communities on the continent. Wits previously hosted AARC&rsquo;s ICRA@40 Africa
        satellite event in 2024.
      </p>
      <p class="mt-4 leading-8 text-slate-300">
        Specific room and arrival details will be shared with registered attendees closer to the date.
      </p>
    </div>

    <!-- Closing CTA -->
    <div class="reveal panel orange-glow rounded-[2rem] p-8 md:p-12 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90">Register your interest</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-white">Be part of ICRA 2026 &mdash; in Africa.</h2>
      <p class="mt-4 max-w-2xl mx-auto text-slate-300 leading-7">
        Spaces at the satellite center are limited. Join our Discord to get the registration link as soon as
        it opens, and to stay across speaker announcements and programme updates.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a href="https://discord.gg/pvXMR8vcpV" target="_blank" rel="noopener noreferrer" class="primary-btn">Join our Discord</a>
        <a href="https://2026.ieee-icra.org/satellite-conference-centers/" target="_blank" rel="noopener noreferrer" class="secondary-btn">About ICRA Satellites</a>
        <a href="/" class="secondary-btn">Back to home</a>
      </div>
    </div>

  </main>

  <footer class="border-t border-white/10 px-6 py-10 text-sm text-slate-500">
    <div class="mx-auto flex max-w-7xl flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <p>&copy; 2026 Akili African Robotics Community</p>
      <p>Robotics &middot; AI &middot; Research &middot; Africa</p>
    </div>
  </footer>

  <script>
    function schedDay(day) {
      // Hide all panels
      document.querySelectorAll('.sched-day').forEach((el) => el.classList.add('hidden'));
      // Reset all tabs
      document.querySelectorAll('.sched-tab').forEach((el) => {
        el.classList.remove('bg-white/10', 'border-white/20', 'text-white', 'font-semibold');
        el.classList.add('border-white/10', 'text-slate-400', 'font-medium');
        el.setAttribute('aria-selected', 'false');
      });
      // Show selected panel
      document.getElementById('panel-' + day)?.classList.remove('hidden');
      // Activate selected tab
      const activeTab = document.getElementById('tab-' + day);
      if (activeTab) {
        activeTab.classList.add('bg-white/10', 'border-white/20', 'text-white', 'font-semibold');
        activeTab.classList.remove('border-white/10', 'text-slate-400', 'font-medium');
        activeTab.setAttribute('aria-selected', 'true');
      }
    }

    // Expose globally for inline onclick handlers
    (window as any).schedDay = schedDay;
  </script>

</BaseLayout>