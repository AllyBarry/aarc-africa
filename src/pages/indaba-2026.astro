---
import BaseLayout from "../layouts/BaseLayout.astro";
import EventNav from "../components/EventNav.astro";

const organisers = [
  { name: "Alexandra Barry", affiliation: "University of the Witwatersrand", image: "/images/people/alexandra.png" },
  { name: "Elisha Komolafe", affiliation: "TODO", image: "/images/people/elisha_komolafe.JPG" },
  { name: "Geraud Nangue Tasse", affiliation: "University of the Witwatersrand", image: "/images/people/geraud.png" },
  { name: "Jenalea Rajab", affiliation: "DEI Projects", image: "/images/people/jenalea.png" },
  { name: "Kamryn Norton", affiliation: "Opti-Num Solutions · African Robotics Unit (UCT)", image: "/images/people/kam.png" },
  { name: "Ndivhuwo Makondo", affiliation: "IBM Research", image: "/images/people/ndivhuwo.png" },
  { name: "Sicelukwanda Zwane", affiliation: "Kinisi Robotics", image: "/images/people/sicelukwanda.png" },
  { name: "Tamlin Love", affiliation: "Institut de Robòtica i Informàtica Industrial (CSIC-UPC)", image: "/images/people/tamlin.jpg" },
  { name: "Zukisa Mbuli", affiliation: "University of the Witwatersrand", image: "/images/people/zukisa.png" },
];

const previousEditions = [
  { label: "Rwanda 2025", href: "https://sites.google.com/view/robot-learning-for-africa-2025/home" },
  { label: "Senegal 2024", href: "https://sites.google.com/view/robotlearning4africa-2024" },
  { label: "Ghana 2023", href: "https://sites.google.com/view/robotlearning4africa" },
];
---

<BaseLayout
  title="4th Workshop on Robotics & Automation in Africa 2026 — AARC"
  description="The 4th Workshop on Robotics and Automation in Africa, hosted at the Deep Learning Indaba 2026 in Lagos, Nigeria — exploring LLMs in Robotics."
  hideNav
>
  <main class="mx-auto max-w-4xl px-6 pt-12 pb-12 lg:px-8">

    <!-- Header -->
    <div class="reveal mb-12">
      <div class="mb-6 flex items-center justify-between gap-4">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-orange-300 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Back to home
        </a>
        <EventNav
          links={[
            { label: "About", href: "#about" },
            { label: "Schedule", href: "#schedule" },
            { label: "Speakers", href: "#speakers" },
            { label: "Organisers", href: "#organisers" },
            { label: "Sponsors", href: "#sponsors" },
          ]}
        />
      </div>
      <p class="mb-4 eyebrow">Workshop · 7th August 2026 · Lagos, Nigeria</p>
      <h1 class="text-3xl md:text-5xl text-white leading-[1.08]">4th Workshop on <span class="text-spark-solid">Robotics &amp; Automation</span> in Africa</h1>
      <p class="mb-5 mt-3 text-lg md:text-xl font-semibold text-slate-300 leading-snug">Theme: LLMs in Robotics</p>
      <p class="max-w-2xl text-base leading-7 text-slate-400">
        Join us in exploring the frontiers of deep learning and LLMs in robotics, and what this technology
        means for the African continent.
      </p>

      <div class="mt-6 flex flex-wrap gap-2.5">
        <span class="chip">In-Person Workshop</span>
        <span class="chip chip-cyan">Pan-Atlantic University</span>
        <span class="chip chip-emerald">Deep Learning Indaba</span>
      </div>
    </div>

    <!-- About -->
    <div id="about" class="reveal scroll-mt-20 panel rounded-3xl p-6 mb-8">
      <p class="mb-1 eyebrow">About</p>
      <h2 class="mt-1 text-xl font-bold text-white">Bringing robotics research to the continent</h2>
      <p class="mt-3 text-sm leading-6 text-slate-300">
        The <strong class="text-white">Workshop on Robotics and Automation in Africa</strong> is an annual
        gathering dedicated to advancing robotics research and practice across the African continent. Now in
        its fourth edition, the workshop focuses on the intersection of large language models and robotic
        systems &mdash; exploring how these technologies can be developed, adapted, and deployed in African
        contexts.
      </p>
      <p class="mt-3 text-sm leading-6 text-slate-300">
        Hosted at the Deep Learning Indaba at <strong class="text-white">Pan-Atlantic University in Lagos,
        Nigeria</strong>, this edition brings together researchers, engineers, students, and industry
        practitioners for a day of tutorials, panels, and community building. The workshop is part of a
        growing series of events committed to nurturing robotics talent across the continent.
      </p>
      <p class="mt-3 text-sm leading-6 text-slate-300">
        The workshop is organised by the <strong class="text-white">Akili African Robotics Community
        (AARC)</strong> &mdash; an organisation dedicated to promoting accessibility, community, and
        education for robotics across Africa.
      </p>
      <div class="mt-5 rounded-2xl border border-orange-400/15 bg-orange-400/5 p-4">
        <p class="mb-2.5 text-sm font-semibold text-orange-200">At a Glance</p>
        <ul class="space-y-1.5 text-sm leading-6 text-slate-300">
          <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">When:</strong>&nbsp;7th August 2026</li>
          <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">Where:</strong>&nbsp;Pan-Atlantic University, Lagos, Nigeria</li>
          <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">Theme:</strong>&nbsp;LLMs in Robotics</li>
          <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">Organised by:</strong>&nbsp;Akili African Robotics Community (AARC)</li>
          <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><strong class="text-white">Open to:</strong>&nbsp;Beginners &amp; Experts</li>
        </ul>
      </div>
    </div>

    <!-- Schedule -->
    <div id="schedule" class="reveal scroll-mt-20 mb-3">
      <p class="mb-2 eyebrow">Programme</p>
      <h2 class="text-2xl font-bold text-white">Workshop Schedule</h2>
    </div>
    <div class="reveal panel rounded-3xl p-6 mb-8">
      <div class="divide-y divide-white/5">
        <div class="flex gap-4 py-3">
          <div class="w-28 shrink-0 pt-0.5 text-xs font-medium text-slate-500">08:30 – 08:50</div>
          <div>
            <span class="mb-1.5 inline-block rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2.5 py-0.5 text-[0.7rem] font-semibold text-cyan-200">Opening</span>
            <p class="text-sm font-semibold text-white">Welcome and Introduction</p>
            <p class="text-xs text-slate-400">Jenalea Rajab</p>
          </div>
        </div>
        <div class="flex gap-4 py-3">
          <div class="w-28 shrink-0 pt-0.5 text-xs font-medium text-slate-500">08:50 – 10:30</div>
          <div>
            <span class="mb-1.5 inline-block rounded-full border border-orange-400/20 bg-orange-400/10 px-2.5 py-0.5 text-[0.7rem] font-semibold text-orange-200">Tutorial</span>
            <p class="text-sm font-semibold text-white">Interactive Tutorial</p>
            <p class="text-xs text-slate-400">Sicelukwanda Zwane, assisted by Jenalea Rajab and Elisha Komolafe</p>
          </div>
        </div>
        <div class="flex gap-4 py-3">
          <div class="w-28 shrink-0 pt-0.5 text-xs font-medium text-slate-500">10:30 – 11:15</div>
          <div>
            <span class="mb-1.5 inline-block rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2.5 py-0.5 text-[0.7rem] font-semibold text-emerald-200">Panel</span>
            <p class="text-sm font-semibold text-white">Panel Discussion</p>
            <p class="text-xs text-slate-400">Dr. Olusola Ayoola, Dayo McIntosh, moderated by Ndivhuwo Makondo</p>
          </div>
        </div>
        <div class="flex gap-4 py-3">
          <div class="w-28 shrink-0 pt-0.5 text-xs font-medium text-slate-500">11:15 – 11:30</div>
          <div>
            <span class="mb-1.5 inline-block rounded-full border border-cyan-400/20 bg-cyan-400/10 px-2.5 py-0.5 text-[0.7rem] font-semibold text-cyan-200">Closing</span>
            <p class="text-sm font-semibold text-white">Closing Remarks and Call to Action</p>
            <p class="text-xs text-slate-400">Jenalea Rajab</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Speakers -->
    <div id="speakers" class="reveal scroll-mt-20 mb-3">
      <p class="mb-2 eyebrow">Speakers</p>
      <h2 class="text-2xl font-bold text-white">Confirmed Speakers</h2>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 mb-8">
      <div class="reveal panel rounded-3xl p-6 text-center sm:text-left">
        <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
          <img
            src="/images/people/olusola_ayoola.jpeg"
            alt="Dr. Olusola Ayoola"
            class="h-24 w-24 shrink-0 rounded-full object-cover border-2 border-white/10"
          />
          <div>
            <p class="text-base font-semibold text-white">Dr. Olusola Ayoola</p>
            <p class="mb-2 text-xs font-medium text-cyan-300">Founder & CEO, Robotics and Artificial Intelligence Nigeria (RAIN)</p>
            <p class="text-sm leading-relaxed text-slate-400">
              Dr. Olusola Sayeed Ayoola is the Founder and CEO of Robotics and Artificial Intelligence Nigeria (RAIN), a leading organisation advancing AI and robotics talent and product development across Africa. He holds a PhD from the University of Manchester and has led groundbreaking projects spanning healthcare, security, and sustainability, including a passenger scream detection system for public buses, upper-limb rehabilitation exoskeletons, and carbon emission tracking drones, alongside smart medical devices such as a gyroscopic arm system for Erb's palsy patients and a smart drug dispenser for dementia care. Under his leadership, RAIN is expanding training programmes across the continent to grow the next generation of AI and robotics talent, and he regularly shares his expertise through keynotes and workshops, including at ICARS 2023 in Abu Dhabi. Widely recognised as a thought leader in the African tech ecosystem, he is a sought-after speaker and collaborator on sustainable technology solutions for Africa's unique challenges.
            </p>
          </div>
        </div>
      </div>
      <div class="reveal panel rounded-3xl p-6 text-center sm:text-left">
        <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
          <img
            src="/images/people/dayo_mcintosh.jpeg"
            alt="Dayo McIntosh"
            class="h-24 w-24 shrink-0 rounded-full object-cover border-2 border-white/10"
          />
          <div>
            <p class="text-base font-semibold text-white">Dayo McIntosh</p>
            <p class="mb-2 text-xs font-medium text-cyan-300">Founder & CEO, Yateou Inc.</p>
            <p class="text-sm leading-relaxed text-slate-400">
              Dayo McIntosh is a founder, strategist, and innovation leader working at the intersection of AI, robotics, cultural commerce, and clean beauty. Raised in a multicultural environment, she brings a cross-cultural lens to building teams, products, and systems that expand access and create opportunity for underrepresented communities. She is best known for building ADE, the first consumer-facing robot for the beauty and wellness industry, an achievement realised without a traditional technical background, through resourcefulness and curiosity. Guided by the belief that innovation is the great equalizer, she continues to build companies at the crossroads of culture and technology, including a new venture currently in stealth, with a mission to empower marginalized people to see themselves as innovators and architects of the future.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Organisers -->
    <div id="organisers" class="reveal scroll-mt-20 mb-3">
      <p class="mb-2 eyebrow">Organisers</p>
      <h2 class="text-2xl font-bold text-white">Meet the team</h2>
    </div>

    <div class="reveal grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 mb-8">
      {organisers.map((person) => (
        <div class="panel flex flex-col items-center gap-2.5 rounded-2xl p-4 text-center">
          <img src={person.image} alt={person.name} class="h-16 w-16 rounded-full object-cover border-2 border-orange-400/25 ring-2 ring-orange-400/10" />
          <div>
            <div class="text-sm font-semibold text-white">{person.name}</div>
            <div class="mt-0.5 text-xs leading-5 text-slate-400">{person.affiliation}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Sponsors -->
    <div id="sponsors" class="reveal scroll-mt-20 mb-3">
      <p class="mb-2 eyebrow">Sponsors</p>
      <h2 class="text-2xl font-bold text-white">Our Sponsors</h2>
    </div>

    <div class="reveal panel rounded-3xl p-6 mb-8">
      <p class="mb-4 text-sm leading-6 text-slate-300">
        We are especially grateful to our sponsors for making this event possible.
      </p>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        {["Sponsor A", "Sponsor B", "Sponsor C", "Sponsor D", "Sponsor E"].map((s) => (
          <div class="flex h-16 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-[0.7rem] uppercase tracking-widest text-slate-500">{s}</div>
        ))}
      </div>
      <p class="mt-4 text-center text-xs text-slate-500">
        Interested in sponsoring?
        <a href="mailto:tlove@iri.upc.edu" class="text-orange-300 hover:text-orange-200 transition-colors">Get in touch</a>
      </p>
    </div>

    <!-- About Us -->
    <div class="reveal mb-3">
      <p class="mb-2 eyebrow">About Us</p>
      <h2 class="text-2xl font-bold text-white">Who we are</h2>
    </div>

    <div class="reveal panel rounded-3xl p-6 mb-8">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
        <p class="text-sm leading-6 text-slate-300">
          The word <strong class="text-white">&ldquo;Akili&rdquo;</strong> comes from Swahili and means
          <em>mind, wisdom, intelligence or ingenuity</em>. It represents the collective wisdom, critical
          thinking and problem solving of African researchers, practitioners, teachers and students. We also
          embrace &ldquo;Akili&rdquo; as a symbol of the artificial mind which we design, create and embed in
          robots. This dual meaning lies at the heart of our community. By bringing together the many minds of
          Africans working in robotics, across borders, disciplines and generations, we can shape a strong and
          inclusive ecosystem on the continent and build better robot minds.
        </p>
      </div>

      <p class="mt-5 text-sm leading-6 text-slate-300">
        <strong class="text-white">Akili African Robotics Community (AARC)</strong> is a network of African
        roboticists seeking to bring together robotics practitioners from across the continent and beyond to
        create a shared space for collaboration, knowledge exchange and mutual support. AARC exists to connect
        people who might otherwise work in isolation and to amplify African voices and innovations in the
        global robotics community.
      </p>
      <p class="mt-3 text-sm leading-6 text-slate-300">
        The world is experiencing a rapid rise in interest and expertise in machine learning, artificial
        intelligence, and robotics, and Africa is no different. Initiatives such as the Deep Learning Indaba
        demonstrate the strength, talent, and momentum of African researchers and practitioners in AI and
        related fields. Across universities, startups, research labs, and innovation hubs, new communities are
        forming and producing world-class work. Robotics is a natural next frontier for this growing ecosystem.
      </p>
      <p class="mt-3 text-sm leading-6 text-slate-300">
        Despite this progress, significant gaps remain. Many aspiring roboticists still face limited access to
        hardware, software, funding, training, and research opportunities. At the same time, there is a lack of
        connectivity between individuals and groups working on robotics across the continent, making
        collaboration, mentorship, and shared learning more difficult than they should be. AARC exists to help
        close these gaps.
      </p>

      <div class="mt-5 rounded-2xl border border-orange-400/15 bg-orange-400/5 p-4">
        <p class="mb-2.5 text-sm font-semibold text-orange-200">Our Mission</p>
        <ul class="space-y-1.5 text-sm leading-6 text-slate-300">
          <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span><strong class="text-white">Promote access</strong> to robots, tools, software, and learning resources for researchers, practitioners and students in Africa.</span></li>
          <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span><strong class="text-white">Foster collaboration</strong> between African roboticists, as well as between academia, industry, and innovation hubs.</span></li>
          <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span><span><strong class="text-white">Educate and inspire</strong> future generations through workshops, research stays, outreach programs, and community-led events at all levels &mdash; from schools to universities and beyond.</span></li>
        </ul>
      </div>

      <p class="mt-5 text-sm leading-6 text-slate-300">
        Through Akili, we aim to build a connected, empowered, and globally visible African robotics community
        which uses shared knowledge and collective &ldquo;mind&rdquo; to solve local and global challenges.
      </p>
    </div>

    <!-- Previous Editions -->
    <div class="reveal mb-3">
      <p class="mb-2 eyebrow">History</p>
      <h2 class="text-2xl font-bold text-white">Previous Editions</h2>
    </div>

    <div class="reveal panel rounded-3xl p-6 mb-8">
      <ul class="flex flex-col gap-2.5">
        {previousEditions.map((edition) => (
          <li>
            <a href={edition.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-cyan-300 hover:text-cyan-200 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              {edition.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Closing CTA -->
    <div class="reveal panel orange-glow rounded-[2rem] p-8 text-center">
      <p class="eyebrow">Stay in the loop</p>
      <h2 class="mt-2 text-2xl md:text-3xl font-bold text-white">Be part of our community!</h2>
      <p class="mt-3 max-w-xl mx-auto text-[0.95rem] text-slate-300 leading-7">
        Join our Discord to keep updated about announcements and programme updates, and to be part of a vibrant
        African robotics community.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-4">
        <a href="https://discord.gg/pvXMR8vcpV" target="_blank" rel="noopener noreferrer" class="primary-btn">Join our Discord</a>
        <a href="/" class="secondary-btn">Back to home</a>
      </div>
    </div>

  </main>

</BaseLayout>
