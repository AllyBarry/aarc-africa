  .avatar-orange { background: rgba(249,115,22,0.15); color: #fdba74; border-color: rgba(249,115,22,0.25); }
  .avatar-cyan { background: rgba(56,189,248,0.12); color: #7dd3fc; border-color: rgba(56,189,248,0.2); }
  .avatar-green { background: rgba(52,211,153,0.12); color: #6ee7b7; border-color: rgba(52,211,153,0.2); }
  .avatar-purple { background: rgba(167,139,250,0.12); color: #c4b5fd; border-color: rgba(167,139,250,0.2); }
