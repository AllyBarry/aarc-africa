  .schedule-table tr { border-bottom: 1px solid var(--border); }
  .schedule-table tr:last-child { border-bottom: none; }
  .schedule-table td { padding: 1rem 0.5rem; font-size: 0.9rem; }
  .time-cell { width: 130px; color: var(--muted); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .session-title { color: var(--text); font-weight: 500; }

  /* CIRCLES GRID */
