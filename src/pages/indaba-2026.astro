<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0f1a;
    --surface: #111827;
    --surface2: #1a2436;
    --border: rgba(255,255,255,0.07);
    --text: #f0f4ff;
    --muted: #8a9bbf;
    --accent: #f97316;
    --accent2: #38bdf8;
    --accent3: #34d399;
    --accent-dim: rgba(249,115,22,0.12);
    --cyan-dim: rgba(56,189,248,0.10);
    --green-dim: rgba(52,211,153,0.10);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    font-size: 16px;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(10,15,26,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 60px;
  }
  .nav-brand { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: var(--accent); text-decoration: none; }
  .nav-links { display: flex; gap: 1.5rem; list-style: none; }
  .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
  .nav-links a:hover { color: var(--text); }

  /* HERO */
  .hero {
    max-width: 900px; margin: 0 auto;
    padding: 5rem 2rem 3rem;
  }
  .back-link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    color: var(--muted); text-decoration: none; font-size: 0.85rem;
    margin-bottom: 2.5rem; transition: color 0.2s;
  }
  .back-link:hover { color: var(--accent); }
  .eyebrow {
    font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 1rem;
  }
  .hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: #a8b8d8;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }
  .hero-desc { color: var(--muted); max-width: 620px; font-size: 1.05rem; margin-bottom: 2rem; }
  .badges { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem; }
  .badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    border-radius: 999px; padding: 0.25rem 0.85rem;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
  }
  .badge-orange { background: var(--accent-dim); border: 1px solid rgba(249,115,22,0.25); color: #fdba74; }
  .badge-cyan { background: var(--cyan-dim); border: 1px solid rgba(56,189,248,0.25); color: #7dd3fc; }
  .badge-green { background: var(--green-dim); border: 1px solid rgba(52,211,153,0.25); color: #6ee7b7; }

  .btn-primary {
    display: inline-block; background: var(--accent); color: #fff;
    border-radius: 0.75rem; padding: 0.7rem 1.5rem;
    font-weight: 600; font-size: 0.9rem; text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: #ea6c06; transform: translateY(-1px); }
  .btn-secondary {
    display: inline-block; background: transparent;
    border: 1px solid rgba(255,255,255,0.15); color: var(--muted);
    border-radius: 0.75rem; padding: 0.7rem 1.5rem;
    font-weight: 500; font-size: 0.9rem; text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover { border-color: rgba(255,255,255,0.3); color: var(--text); }
  .btn-row { display: flex; flex-wrap: wrap; gap: 0.75rem; }

  /* SECTIONS */
  .section { max-width: 900px; margin: 0 auto; padding: 2.5rem 2rem; }
  .section-label {
    font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(249,115,22,0.8); margin-bottom: 0.5rem;
  }
  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem); color: var(--text);
    margin-bottom: 1.5rem;
  }

  /* PANEL */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    padding: 2rem;
    margin-bottom: 1rem;
  }

  /* GLANCE LIST */
  .glance-list { list-style: none; space-y: 0.5rem; }
  .glance-list li {
    display: flex; gap: 0.75rem; align-items: flex-start;
