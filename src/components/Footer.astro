---
const year = 2026;
const discord = "https://discord.gg/pvXMR8vcpV";
const linkedin = "https://www.linkedin.com/company/aarc-africa";

const links = [
  { label: "About", href: "/#about" },
  { label: "Events", href: "/#events" },
  { label: "Network", href: "/#network" },
  { label: "Committee", href: "/#committee" },
  { label: "Charter", href: "/charter" },
];
---

<footer id="contact" class="relative mt-28 border-t border-white/8">
  <div class="hairline absolute inset-x-0 top-0 opacity-50"></div>

  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
    <!-- Brand -->
    <a href="/" class="group inline-flex items-center gap-2.5" aria-label="AARC home">
      <span class="brand-type text-2xl text-white">AARC</span>
      <span class="h-1.5 w-1.5 rounded-full bg-spark shadow-[0_0_12px_var(--spark)] transition-transform duration-500 group-hover:scale-150"></span>
    </a>

    <!-- Subtext -->
    <p class="mt-5 max-w-md text-sm leading-7 text-slate-400">
      A network of African roboticists — connecting practitioners across the
      continent and beyond, and amplifying African voices in global robotics.
    </p>

    <!-- Page links + social -->
    <div class="mt-8 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <nav class="flex flex-wrap items-center gap-x-8 gap-y-3">
        {links.map((l) => (
          <a
            href={l.href}
            class="group inline-flex items-center gap-2 text-sm text-slate-400 transition-colors hover:text-white"
          >
            <span class="h-px w-0 bg-spark transition-all duration-300 group-hover:w-4"></span>
            {l.label}
          </a>
        ))}
      </nav>

      <div class="flex gap-3">
        <a href={discord} target="_blank" rel="noopener noreferrer" aria-label="Discord" class="grid h-10 w-10 place-items-center rounded-xl border border-white/10 bg-white/5 text-slate-300 transition hover:border-orange-400/40 hover:bg-orange-400/5 hover:text-orange-200">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.74 19.74 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
        </a>
        <a href={linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="grid h-10 w-10 place-items-center rounded-xl border border-white/10 bg-white/5 text-slate-300 transition hover:border-orange-400/40 hover:bg-orange-400/5 hover:text-orange-200">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 18.34V9.99H5.67v8.35h2.67zM7 8.84a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1zm11.34 9.5v-4.57c0-2.45-1.31-3.59-3.06-3.59a2.64 2.64 0 0 0-2.39 1.31v-1.13H10.2v8.35h2.67v-4.41c0-1.16.22-2.28 1.66-2.28 1.42 0 1.44 1.32 1.44 2.35v4.34h2.67z"/></svg>
        </a>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-white/8 pt-7 text-xs uppercase tracking-[0.18em] text-slate-500 md:flex-row md:items-center md:justify-between">
      <p>&copy; {year} Akili African Robotics Community</p>
      <p>Robotics · AI · Research · Africa</p>
    </div>
  </div>
</footer>
