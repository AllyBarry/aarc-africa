---
interface Props {
    eyebrow: string;
    title: string;
    text: string;
}
const { eyebrow, title, text } = Astro.props;
---

<div class="reveal max-w-2xl">
    <p
        class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-orange-300/90"
    >
        {eyebrow}
    </p>
    <h2 class="section-title text-3xl text-white md:text-4xl">
        {title}
    </h2>
    <p class="mt-4 text-base leading-7 text-slate-400 md:text-lg">
        {text}
    </p>
</div>
