---
interface Props {
  eyebrow: string;
  title: string;
  text?: string;
  align?: "left" | "center";
}
const { eyebrow, title, text, align = "left" } = Astro.props;
const centered = align === "center";
---

<div class={`reveal ${centered ? "mx-auto max-w-2xl text-center" : "max-w-2xl"}`}>
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="mt-4 text-3xl text-white md:text-[2.6rem] md:leading-[1.08]">
    {title}
  </h2>
  {text && (
    <p class={`mt-5 text-base leading-7 text-slate-400 md:text-lg ${centered ? "mx-auto" : ""}`}>
      {text}
    </p>
  )}
</div>
