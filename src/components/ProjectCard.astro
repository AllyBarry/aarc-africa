---
interface Props {
  title: string;
  text: string;
  tags: string[];
  buttonUrl?: string;
}
const { title, text, tags, buttonUrl } = Astro.props;
---

<article class="project-card panel rounded-3xl p-6">
  <div class="mb-4 inline-flex rounded-full border border-orange-400/20 bg-orange-400/10 px-3 py-1 text-xs font-medium text-orange-200">
    Robotics + AI
  </div>
  <h3 class="text-xl font-semibold text-white">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-400">{text}</p>

  <div class="mt-6 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-300">
        {tag}
      </span>
    ))}
  </div>

  {buttonUrl && (
    <a
      href={buttonUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-6 inline-flex items-center gap-2 rounded-full border border-amber-400/40 bg-gradient-to-r from-orange-500/20 to-amber-400/20 px-4 py-2 text-sm font-medium text-amber-300 transition-all hover:border-amber-400/70 hover:from-orange-500/30 hover:to-amber-400/30 hover:text-amber-200"
    >
      Visit Website
    </a>
  )}
</article>