---
export interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<div class="tech-panel edge-pulse p-6">
  <div class="mb-4 h-10 w-10 rounded-xl bg-gradient-to-br from-orange-400/20 to-cyan-300/10 ring-1 ring-white/10"></div>
  <h3 class="font-display text-xl font-semibold">{title}</h3>
  <p class="mt-3 leading-7 text-soft">{body}</p>
</div>